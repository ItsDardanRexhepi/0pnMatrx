# 0pnMatrx environment overrides
#
# Copy to `.env` and fill in the values you want to override.
# Anything set here takes precedence over openmatrix.config.json.

# ── Gateway ──
# OPENMATRIX_API_KEY=
# OPENMATRIX_HOST=0.0.0.0
# OPENMATRIX_PORT=18790
# PORT=                        # Railway/Heroku assign this automatically; takes precedence

# ── Model providers ──
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# NVIDIA_API_KEY=
# GOOGLE_API_KEY=

# ── Blockchain ──
# BASE_RPC_URL=https://sepolia.base.org

# ── Notifications ──
# Set any subset. Run `python setup_communications.py` for guided setup.
# Telegram
# TELEGRAM_BOT_TOKEN=
# OWNER_TELEGRAM_ID=           # Your Telegram chat ID
# Discord
# DISCORD_WEBHOOK_URL=
# Slack
# SLACK_WEBHOOK_URL=
# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_TO=
# SMS / WhatsApp (Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_TO_NUMBER=
# TWILIO_WHATSAPP_FROM=        # e.g. +14155238886 (Twilio sandbox)
# TWILIO_WHATSAPP_TO=
# iOS push (APNs) — for the MTRX iOS app
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.opnmatrx.mtrx
# Generic webhook
# NOTIFY_WEBHOOK_URL=
# NOTIFY_WEBHOOK_BEARER=

# ── Social media ──
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# DISCORD_ANNOUNCEMENTS_WEBHOOK=

# ── Protocol Integrations ────────────────────────────────────
# DeFi
# AAVE_ENDPOINT=
# COMPOUND_ENDPOINT=
# UNISWAP_ROUTER=
# CURVE_REGISTRY=

# Bridge
# STARGATE_ENDPOINT=
# HOP_ENDPOINT=
# ACROSS_ENDPOINT=

# Storage
# IPFS_API_URL=http://localhost:5001
# ARWEAVE_GATEWAY=https://arweave.net
# FILECOIN_API_URL=

# Social
# XMTP_ENV=production

# Carbon Markets
# TOUCAN_PROTOCOL_ADDRESS=
# KLIMA_DAO_ADDRESS=

# Prediction Markets
# POLYMARKET_API_KEY=
