# 0pnMatrx environment overrides
#
# Copy to `.env` and fill in the values you want to override.
# Anything set here takes precedence over openmatrix.config.json.

# ── Gateway ──
# OPENMATRIX_API_KEY=
# OPENMATRIX_HOST=0.0.0.0
# OPENMATRIX_PORT=18790
# PORT=                        # Railway/Heroku assign this automatically; takes precedence

# ── Model providers ──
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# NVIDIA_API_KEY=
# GOOGLE_API_KEY=

# ── Blockchain ──
# BASE_RPC_URL=https://sepolia.base.org

# ── Notifications ──
# TELEGRAM_BOT_TOKEN=
# OWNER_TELEGRAM_ID=          # Your Telegram user ID — used by the bridge approval gate

# ── Social media ──
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# DISCORD_WEBHOOK_URL=
# DISCORD_ANNOUNCEMENTS_WEBHOOK=

# ── Protocol Integrations ────────────────────────────────────
# DeFi
# AAVE_ENDPOINT=
# COMPOUND_ENDPOINT=
# UNISWAP_ROUTER=
# CURVE_REGISTRY=

# Bridge
# STARGATE_ENDPOINT=
# HOP_ENDPOINT=
# ACROSS_ENDPOINT=

# Storage
# IPFS_API_URL=http://localhost:5001
# ARWEAVE_GATEWAY=https://arweave.net
# FILECOIN_API_URL=

# Social
# XMTP_ENV=production

# Carbon Markets
# TOUCAN_PROTOCOL_ADDRESS=
# KLIMA_DAO_ADDRESS=

# Prediction Markets
# POLYMARKET_API_KEY=
