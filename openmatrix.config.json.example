    "platform_wallet": "YOUR_PLATFORM_WALLET_ADDRESS"
  },
  "notifications": {
    "telegram": {
      "bot_token": "YOUR_TELEGRAM_BOT_TOKEN",
      "owner_id": "YOUR_TELEGRAM_USER_ID"
    }
  }
