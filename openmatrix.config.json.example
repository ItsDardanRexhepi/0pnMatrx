{
  "platform": "0pnMatrx",
  "version": "1.0.0",
  "workspace": ".",
  "timezone": "America/Los_Angeles",
  "max_steps": 10,
  "model": {
    "provider": "ollama",
    "primary": "llama3.1",
    "fallback": "mistral",
