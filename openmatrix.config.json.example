      },
      "gemini": {
        "api_key": "YOUR_GOOGLE_API_KEY",
        "model": "gemini-pro"
      }
    }
  },
  "gateway": {
    "port": 18790,
    "host": "0.0.0.0"
  },
  "agents": {
    "neo": {
      "enabled": true,
      "role": "execution"
    },
    "trinity": {
      "enabled": true,
      "role": "conversation"
    },
    "morpheus": {
      "enabled": true,
      "role": "guidance"
    }
  },
  "blockchain": {
    "network": "base-sepolia",
    "rpc_url": "YOUR_BASE_RPC_URL",
    "chain_id": 84532,
    "eas_contract": "0xA1207F3BBa224E2c9c3c6D5aF63D0eb1582Ce587",
    "eas_schema": "YOUR_EAS_SCHEMA_UID",
    "paymaster_address": "YOUR_PAYMASTER_ADDRESS",
